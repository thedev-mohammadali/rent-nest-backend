model RentalAgreement {
    id              String @id @default(uuid()) @db.Uuid
    rentalRequestId String @unique @map("rental_request_id") @db.Uuid
    tenantId        String @map("tenant_id") @db.Uuid
    propertyId      String @map("property_id") @db.Uuid

    monthlyRent      Decimal @map("monthly_rent") @db.Decimal(10, 2)
    durationInMonths Int     @map("duration_in_months")

    leaseStartDate DateTime @map("lease_start_date") @db.Date
    leaseEndDate   DateTime @map("lease_end_date") @db.Date

    status RentalAgreementStatus @default(PENDING_PAYMENT)

    activatedAt DateTime? @map("activated_at") @db.Timestamptz(3)

    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

    rentalRequest RentalRequest @relation(fields: [rentalRequestId], references: [id])
    tenant        User          @relation(fields: [tenantId], references: [id])
    property      Property      @relation(fields: [propertyId], references: [id])

    payments Payment[]

    @@index([tenantId])
    @@index([propertyId])
    @@map("rental_agreements")
}
