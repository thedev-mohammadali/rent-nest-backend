PORT=port_number
DATABASE_URL=your_database_url
BCRYPT_SALT_ROUNDS=salt_rounds
NODE_ENV=development | production

JWT_ACCESS_SECRET=jwt secret key
JWT_REFRESH_SECRET=jwt refresh secret key

JWT_ACCESS_EXPIRES_IN=token expiry time
JWT_REFRESH_EXPIRES_IN=refresh token expiry time

STRIPE_SECRET_KEY=your stripe secret key

STRIPE_WEBHOOK_SECRET=your webhook secret

STRIPE_SUCCESS_URL=http://localhost:3000/api/payments/success
STRIPE_CANCEL_URL=http://localhost:3000/api/payments/cancel